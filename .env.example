# ╔══════════════════════════════════════════════════════════════╗
# ║  search-sanitizer configuration                             ║
# ║  Copy this file to .env and edit to match your setup        ║
# ║                                                              ║
# ║  cp .env.example .env                                       ║
# ╚══════════════════════════════════════════════════════════════╝

# ── LLM Provider ─────────────────────────────────────────────
# Any OpenAI-compatible or Ollama endpoint works.
#
# Ollama (default):
#   OLLAMA_URL=http://host.docker.internal:11434
#
# LM Studio:
#   OLLAMA_URL=http://host.docker.internal:1234
#   LLM_API_FORMAT=openai
#
# OpenCode loop proxy:
#   OLLAMA_URL=http://host.docker.internal:4200
#   LLM_API_FORMAT=openai
#
# text-generation-webui:
#   OLLAMA_URL=http://host.docker.internal:5000
#   LLM_API_FORMAT=openai
#
# Any remote OpenAI-compatible API:
#   OLLAMA_URL=https://your-api.example.com
#   LLM_API_FORMAT=openai
#   LLM_API_KEY=sk-your-key-here

OLLAMA_URL=http://host.docker.internal:11434

# API format: "ollama" (native /api/chat) or "openai" (/v1/chat/completions)
LLM_API_FORMAT=ollama

# API key (only needed for remote/authenticated endpoints, leave blank for local)
LLM_API_KEY=

# ── Models ───────────────────────────────────────────────────
# FILTER_MODEL: Used for /search/direct and /search (fast, coding searches)
# SECURITY_MODEL: Used for /search/security (thorough, security assessments)
#
# Ollama examples:
#   FILTER_MODEL=qwen3:4b
#   FILTER_MODEL=llama3.2:3b
#   FILTER_MODEL=gemma3:4b
#   SECURITY_MODEL=qwen3.5-128k:latest
#   SECURITY_MODEL=qwen3-coder:30b-64k
#
# OpenAI-compatible examples (LM Studio, text-gen-webui, vLLM):
#   FILTER_MODEL=local-model
#   SECURITY_MODEL=local-model

FILTER_MODEL=qwen3:4b
SECURITY_MODEL=qwen3.5-128k:latest

# ── Context Window ───────────────────────────────────────────
# Match to your model's actual context window (in tokens).
# This controls how much fetched content is assembled for filtering.
#
# Common sizes:
#   qwen3:4b          → 32768
#   llama3.2:3b       → 131072
#   qwen3.5-128k      → 131072
#   qwen3-coder:30b   → 65536

FILTER_CONTEXT_WINDOW=32768
SECURITY_CONTEXT_WINDOW=131072

# ── Search Tuning ────────────────────────────────────────────
# How many pages to fetch and process per search query.
# More pages = better coverage but slower (each goes through OCR).

MAX_PAGES_TO_FETCH=6
MAX_PAGE_CHARS=20000
RESULTS_PER_QUERY=5

# ── OCR Settings ─────────────────────────────────────────────
# OCR sanitization is ON by default for all search paths.
# Disable only if you need raw speed and accept the security tradeoff.

OCR_ENABLED=true

# DPI for text rendering (300 = Tesseract recommended minimum)
OCR_DPI=300

# Font size in points (20pt at 300dpi gives ~30px cap height, optimal range)
OCR_POINTSIZE=20

# Image width in pixels (wider = more chars per line, fewer wrapping artifacts)
OCR_WIDTH=2400

# ── SearXNG (usually no need to change) ──────────────────────
SEARXNG_URL=http://searxng:8080
