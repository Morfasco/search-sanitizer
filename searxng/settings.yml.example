use_default_settings: true

general:
  instance_name: "search-sanitizer"
  debug: false

server:
  secret_key: "CHANGE_ME_GENERATE_WITH_openssl_rand_-hex_32"
  bind_address: "0.0.0.0:8080"
  limiter: false
  image_proxy: false
  method: "GET"

search:
  safe_search: 1
  autocomplete: ""
  default_lang: "en"
  formats:
    - html
    - json

engines:
  - name: google
    engine: google
    shortcut: g
    disabled: false
  - name: duckduckgo
    engine: duckduckgo
    shortcut: ddg
    disabled: false
  - name: github
    engine: github
    shortcut: gh
    disabled: false
  - name: stackoverflow
    engine: stackoverflow
    shortcut: so
    disabled: false
  - name: wikipedia
    engine: wikipedia
    shortcut: wp
    disabled: false
  - name: bing
    engine: bing
    shortcut: bi
    disabled: false
  - name: brave
    engine: brave
    shortcut: br
    disabled: false
